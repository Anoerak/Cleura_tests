{% extends 'base.html.twig' %}

{% block title %}Cleura | Home
{% endblock %}

{% block body %}
	<div id="cleura-htmx">
		<section
			id="home">
			{# If connected and if only USER #}
			{% if app.user and app.user.roles[0] == 'ROLE_USER' %}
				<h1>
					Welcome
					{{ app.user.name }}
				</h1>
				<div class="dashboard">
					<a hx-target='#cleura-htmx' hx-swap='innerHTML' hx-get={{ path('app_forum')}} {# href={path} #} id='card'>

						<div class='card'>
							<div class='card__title'>
								<h3>Forums</h3>
							</div>
							<div class='card__image'>
								<img src={{ asset('build/images/forum-icon.png') }} alt='An icon of chat bubbles'/>
							</div>
							<div class='card__description'>
								<p>Get access to all our forums..</p>
							</div>
						</div>
					</a>
					<a hx-target='#cleura-htmx' hx-swap='innerHTML' hx-get={{ path('app_user_edit', {'id': app.user.id} ) }} {# href={path} #} id='card'>

						<div class='card'>
							<div class='card__title'>
								<h3>Profile</h3>
							</div>
							<div class='card__image'>
								<img src={{ asset('build/images/profile-icon.png') }} alt='An icon of a neutral gender person'/>
							</div>
							<div class='card__description'>
								<p>Get access/modify your profil informations.</p>
							</div>
						</div>
					</a>

				</div>
				{# If connected and if only ADMIN #}
			{% elseif app.user and app.user.roles[0] == 'ROLE_ADMIN' %}
				<h1>Welcome
					{{ app.user.name }}</h1>
				<div class="dashboard">
					<div {{ react_component( 'card/Card', { 'title': 'Forums', 'description': 'Get access to all our forums..', 'path': '/forum', 'image': 'build/images/forum-icon.png', 'imageAlt': 'An icon of chat bubbles' } ) }}>
						Loading...
						<i class="fas fa-cog fa-spin fa-2x"></i>
					</div>
					<div {{ react_component( 'card/Card', { 'title': 'Profile', 'description': 'Get access/modify your profil informations.', 'path': "/user/#{app.user.id}/edit", 'image' : 'build/images/profile-icon.png' , 'imageAlt' : 'An icon of a neutral gender person' } ) }}>
						Loading...
						<i class="fas fa-cog fa-spin fa-2x"></i>
					</div>
					<div {{ react_component( 'card/Card', { 'title': 'Admin Dashboard', 'description': 'Manage the forums, posts and users. ', 'path': "/admin", 'image' : 'build/images/dashboard-icon.png' , 'imageAlt' : 'An icon of a dashboard with random graphs' } ) }}>

						Loading...
						<i class="fas fa-cog fa-spin fa-2x"></i>
					</div>
				</div>
				{# If not connected #}
			{% else %}
				<h1>Welcome to Cleura's Forum
				</h1>
				<div id="login-htmx">
					<h2>'Development Evaluation Test'</h2>
					<h3>Click on the 'Get Started' button to signin</h3>
				</div>
				<p>For the admin profile, use the email: "admin@admin.se" and the password
					<strong>Cleur@2023</strong>
				</p>
				<p>For the user profile, use the email: "user@user.se" and the password
					<strong>Cleur@2023</strong>
				</p>
			{% endif %}
			{# </div> #}
		</section>
	</div>
{% endblock %}
